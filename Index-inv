<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <title>Control de Stock</title>
    
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <style>
      :root {
        --bg: #0d1117;
        --card: #161b22;
        --card-elevated: #1c2128;
        --border: #30363d;
        --text: #c9d1d9;
        --text-bright: #ffffff;
        --text-muted: #8b949e;
        --accent: #365BA5;
        --accent-light: #4a7fd4;
        --success: #238636;
        --success-bg: rgba(35, 134, 54, 0.15);
        --danger: #da3633;
        --danger-bg: rgba(218, 54, 51, 0.15);
        --warning: #d29922;
        --warning-bg: rgba(210, 153, 34, 0.15);
        --overlay: rgba(0,0,0,0.8);
        
        /* WCAG Touch targets - 48px minimum */
        --touch-min: 48px;
        --touch-comfortable: 56px;
      }

      * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: 'Inter', sans-serif;
        margin: 0; padding: 0;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        min-height: 100vh;
      }

      /* === LOGIN === */
      #login-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: var(--bg);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999;
        transition: opacity 0.3s ease;
        padding: 20px;
      }

      .login-card {
        background: var(--card);
        border: 1px solid var(--border);
        padding: 40px 32px;
        border-radius: 20px;
        text-align: center;
        width: 100%; max-width: 340px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      }

      .login-icon { 
        margin-bottom: 24px; 
        color: var(--accent);
        background: rgba(54, 91, 165, 0.1);
        width: 80px; height: 80px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin-left: auto; margin-right: auto;
      }

      .login-title { margin: 0 0 8px; font-size: 1.5rem; font-weight: 800; color: var(--text-bright); }
      .login-subtitle { margin: 0 0 24px; font-size: 0.9rem; color: var(--text-muted); }

      .login-input {
        width: 100%; padding: 16px; margin-bottom: 16px;
        background: var(--bg); border: 2px solid var(--border);
        color: white; border-radius: 12px; font-size: 1.5rem;
        text-align: center; letter-spacing: 8px; font-weight: 700;
      }
      .login-input:focus { border-color: var(--accent); outline: none; background: #0a0d12; }
      .login-input::placeholder { letter-spacing: 4px; color: var(--text-muted); }

      .btn-login {
        width: 100%; padding: 16px; background: var(--accent);
        color: white; border: none; border-radius: 12px;
        font-weight: 800; font-size: 1rem; cursor: pointer;
        min-height: var(--touch-comfortable);
        transition: all 0.2s;
      }
      .btn-login:hover { background: var(--accent-light); }
      .btn-login:active { transform: scale(0.98); }
      .btn-login:disabled { opacity: 0.6; cursor: not-allowed; }

      .login-msg {
        margin-top: 16px; padding: 12px; border-radius: 8px;
        font-size: 0.9rem; font-weight: 600; min-height: 44px;
        display: flex; align-items: center; justify-content: center; gap: 8px;
      }
      .login-msg.error { background: var(--danger-bg); color: var(--danger); }
      .login-msg.loading { background: var(--warning-bg); color: var(--warning); }
      .login-msg:empty { display: none; }

      /* === HEADER === */
      .header {
        position: sticky; top: 0;
        background: rgba(13, 17, 23, 0.97);
        backdrop-filter: blur(12px);
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        z-index: 100;
        display: flex; flex-direction: column; gap: 12px;
      }

      .header-top { display: flex; justify-content: space-between; align-items: center; }
      .header-left { display: flex; align-items: center; gap: 12px; }

      .app-title {
        font-size: 1.1rem; font-weight: 800; color: var(--text-bright);
        display: flex; align-items: center; gap: 8px;
      }

      .user-badge {
        font-size: 0.75rem; color: var(--accent);
        background: rgba(54, 91, 165, 0.15);
        border: 1px solid rgba(54, 91, 165, 0.3);
        padding: 6px 10px; border-radius: 8px; font-weight: 600;
      }

      .header-actions { display: flex; gap: 8px; }

      .icon-btn {
        background: var(--card); border: 1px solid var(--border);
        color: var(--text);
        width: var(--touch-min); height: var(--touch-min);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all 0.2s;
        position: relative;
      }
      .icon-btn:hover { background: var(--card-elevated); color: var(--text-bright); }
      .icon-btn:active { transform: scale(0.95); }
      .icon-btn.active { background: var(--accent); border-color: var(--accent); color: white; }

      .icon-btn .badge {
        position: absolute; top: -4px; right: -4px;
        background: var(--accent); color: white;
        font-size: 0.65rem; font-weight: 800;
        min-width: 18px; height: 18px; border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        padding: 0 4px;
      }

      /* Search */
      .search-wrapper { position: relative; width: 100%; }
      .search-input {
        width: 100%; background: var(--card); border: 1px solid var(--border);
        color: var(--text-bright); padding: 14px 44px 14px 44px;
        border-radius: 12px; font-size: 1rem;
      }
      .search-input:focus { outline: none; border-color: var(--accent); background: var(--card-elevated); }
      .search-input::placeholder { color: var(--text-muted); }
      .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted); pointer-events: none; }

      .clear-btn {
        position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
        background: var(--border); border: none; color: var(--text-muted);
        width: 28px; height: 28px; border-radius: 50%;
        display: none; align-items: center; justify-content: center; cursor: pointer;
      }
      .clear-btn.show { display: flex; }
      .clear-btn:hover { background: var(--text-muted); color: var(--bg); }

      /* Filter Pills */
      .filter-row {
        display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px;
        -webkit-overflow-scrolling: touch; scrollbar-width: none;
      }
      .filter-row::-webkit-scrollbar { display: none; }

      .filter-pill {
        padding: 8px 14px; border-radius: 20px;
        font-size: 0.8rem; font-weight: 600;
        border: 1px solid var(--border); background: transparent;
        color: var(--text-muted); cursor: pointer;
        white-space: nowrap; transition: all 0.15s; min-height: 36px;
      }
      .filter-pill:hover { border-color: var(--text-muted); color: var(--text); }
      .filter-pill.active { background: var(--accent); border-color: var(--accent); color: white; }

      /* === GRID === */
      .grid-container {
        display: grid; grid-template-columns: 1fr;
        gap: 12px; padding: 12px; padding-bottom: 100px;
        max-width: 1200px; margin: 0 auto;
      }
      @media (min-width: 600px) {
        .grid-container { grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; padding: 16px; }
      }

      /* === CARD === */
      .card { 
        background: var(--card); border: 1px solid var(--border); 
        border-radius: 16px; overflow: hidden; transition: all 0.2s;
      }
      .card.bookmarked {
        border-color: var(--warning);
        background: linear-gradient(135deg, rgba(210, 153, 34, 0.08) 0%, var(--card) 100%);
      }

      .card-header {
        display: flex; justify-content: space-between; align-items: flex-start;
        padding: 14px 14px 10px; border-bottom: 1px solid var(--border);
      }

      .card-meta { display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 0; }
      .card-brand { font-size: 0.7rem; text-transform: uppercase; color: var(--text-muted); font-weight: 700; letter-spacing: 0.5px; }
      .card-title { font-weight: 700; color: var(--text-bright); line-height: 1.3; font-size: 1rem; word-break: break-word; }

      .card-actions { display: flex; gap: 6px; margin-left: 12px; }

      .card-btn {
        width: 44px; height: 44px;
        background: var(--bg); border: 1px solid var(--border);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: var(--text-muted); transition: all 0.15s;
      }
      .card-btn:hover { background: var(--card-elevated); color: var(--text); }
      .card-btn:active { transform: scale(0.95); }
      .card-btn.bookmarked { color: var(--warning); background: var(--warning-bg); border-color: var(--warning); }

      .card-body { padding: 14px; display: flex; flex-direction: column; gap: 12px; }

      /* Fields */
      .field-group { display: flex; gap: 12px; }
      .field { flex: 1; display: flex; flex-direction: column; gap: 6px; }
      .field-label {
        font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
        color: var(--text-muted); display: flex; align-items: center; gap: 6px;
      }
      .field-input-wrapper { display: flex; gap: 8px; align-items: center; }

      .field-input {
        flex: 1; background: var(--bg); border: 2px solid var(--border);
        color: var(--text-bright); padding: 12px; border-radius: 10px;
        font-size: 1rem; font-weight: 600; transition: all 0.2s;
        min-height: var(--touch-min);
      }
      .field-input:focus { outline: none; border-color: var(--accent); background: #0a0d12; }
      .field-input.modified { border-color: var(--warning); background: var(--warning-bg); }
      .field-input.saved { border-color: var(--success); background: var(--success-bg); }
      .field-input.stock-field { text-align: center; font-size: 1.3rem; font-weight: 800; max-width: 100px; }

      /* Save Button */
      .save-btn {
        background: var(--success); border: none; color: white;
        width: var(--touch-min); height: var(--touch-min);
        border-radius: 10px;
        display: none; align-items: center; justify-content: center;
        cursor: pointer; transition: all 0.2s; flex-shrink: 0;
      }
      .save-btn.show { display: flex; }
      .save-btn:hover { background: #2ea043; }
      .save-btn:active { transform: scale(0.95); }
      .save-btn:disabled { background: var(--border); cursor: not-allowed; }
      .save-btn.saving { background: var(--warning); }

      /* Quick Actions */
      .quick-actions {
        display: flex; gap: 8px; padding-top: 8px;
        border-top: 1px solid var(--border);
      }

      .quick-btn {
        flex: 1;
        display: flex; align-items: center; justify-content: center; gap: 6px;
        padding: 12px; background: var(--bg); border: 1px solid var(--border);
        border-radius: 10px; color: var(--text-muted);
        font-size: 0.85rem; font-weight: 700; cursor: pointer;
        transition: all 0.15s; min-height: 48px;
      }
      .quick-btn:hover { background: var(--card-elevated); color: var(--text); }
      .quick-btn:active { transform: scale(0.98); }
      .quick-btn.danger:hover { background: var(--danger-bg); color: var(--danger); border-color: var(--danger); }

      /* === SIDE MENU === */
      .menu-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: var(--overlay); z-index: 200;
        opacity: 0; visibility: hidden; transition: all 0.3s ease;
      }
      .menu-overlay.open { opacity: 1; visibility: visible; }

      .side-menu {
        position: fixed; top: 0; right: 0;
        width: 300px; max-width: 85vw; height: 100%;
        background: var(--bg); border-left: 1px solid var(--border);
        z-index: 201;
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex; flex-direction: column;
        box-shadow: -8px 0 30px rgba(0,0,0,0.5);
      }
      .side-menu.open { transform: translateX(0); }

      .menu-header {
        padding: 20px; border-bottom: 1px solid var(--border);
        display: flex; justify-content: space-between; align-items: center;
      }
      .menu-title { font-weight: 800; font-size: 1.2rem; color: var(--text-bright); }

      .menu-content {
        flex: 1; overflow-y: auto; padding: 12px;
        display: flex; flex-direction: column; gap: 8px;
      }

      .menu-section-title {
        font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
        color: var(--text-muted); padding: 8px 12px; letter-spacing: 0.5px;
      }

      .cat-btn {
        background: transparent; border: 1px solid var(--border);
        color: var(--text); padding: 14px; border-radius: 12px;
        text-align: left; cursor: pointer; font-size: 0.95rem;
        display: flex; align-items: center; gap: 10px;
        transition: all 0.15s; min-height: var(--touch-min);
      }
      .cat-btn:hover { background: var(--card); border-color: var(--text-muted); }
      .cat-btn.active { background: var(--accent); border-color: var(--accent); color: white; font-weight: 600; }

      .menu-footer {
        padding: 16px; border-top: 1px solid var(--border); background: var(--card);
      }

      .btn-logout {
        width: 100%; padding: 14px;
        background: var(--danger-bg); border: 1px solid var(--danger);
        color: var(--danger); border-radius: 12px;
        font-weight: 700; cursor: pointer;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        transition: all 0.2s; min-height: var(--touch-min);
      }
      .btn-logout:hover { background: var(--danger); color: white; }

      /* === STATES === */
      .empty-state { grid-column: 1 / -1; text-align: center; padding: 60px 20px; }
      .empty-icon { font-size: 3rem; margin-bottom: 16px; opacity: 0.5; }
      .empty-title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }
      .empty-text { font-size: 0.9rem; color: var(--text-muted); }

      .loading-state { grid-column: 1 / -1; text-align: center; padding: 60px 20px; color: var(--text-muted); }
      .spinner {
        width: 40px; height: 40px;
        border: 3px solid var(--border); border-top-color: var(--accent);
        border-radius: 50%; animation: spin 1s linear infinite;
        margin: 0 auto 16px;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* Toast */
      .toast {
        position: fixed; bottom: 20px; left: 50%;
        transform: translateX(-50%) translateY(100px);
        background: var(--card-elevated); border: 1px solid var(--border);
        padding: 14px 20px; border-radius: 12px;
        font-weight: 600; display: flex; align-items: center; gap: 10px;
        z-index: 1000; box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .toast.show { transform: translateX(-50%) translateY(0); }
      .toast.success { border-color: var(--success); color: var(--success); }
      .toast.error { border-color: var(--danger); color: var(--danger); }

      /* Hide spinners */
      input::-webkit-outer-spin-button,
      input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
      input[type=number] { -moz-appearance: textfield; }

      .spinning { animation: spin 1s linear infinite; }
    </style>
  </head>
  <body>

    <!-- LOGIN -->
    <div id="login-overlay">
      <div class="login-card">
        <div class="login-icon"><i data-lucide="package-search" size="36"></i></div>
        <h2 class="login-title">Inventario</h2>
        <p class="login-subtitle">Ingresa tu código de acceso</p>
        <input type="tel" id="login-key" class="login-input" placeholder="••••" maxlength="4" inputmode="numeric" pattern="[0-9]*" onkeydown="handleLoginKey(event)">
        <button class="btn-login" id="loginBtn" onclick="attemptLogin()">INGRESAR</button>
        <div id="login-msg" class="login-msg"></div>
      </div>
    </div>

    <!-- APP -->
    <div id="app-content" style="display:none;">
      <div id="menuOverlay" class="menu-overlay" onclick="toggleMenu()"></div>

      <div id="sideMenu" class="side-menu">
        <div class="menu-header">
          <span class="menu-title">Filtros</span>
          <button class="icon-btn" onclick="toggleMenu()"><i data-lucide="x" size="20"></i></button>
        </div>
        <div class="menu-content">
          <div class="menu-section-title">Categorías</div>
          <div id="categoriesList"><div class="loading-state"><div class="spinner"></div></div></div>
        </div>
        <div class="menu-footer">
          <button class="btn-logout" onclick="logout()"><i data-lucide="log-out" size="18"></i> Cerrar Sesión</button>
        </div>
      </div>

      <div class="header">
        <div class="header-top">
          <div class="header-left">
            <div class="app-title"><i data-lucide="package" size="20"></i> Stock</div>
            <div id="userBadge" class="user-badge" style="display:none;"></div>
          </div>
          <div class="header-actions">
            <button class="icon-btn" id="bookmarkToggle" onclick="toggleBookmarkView()">
              <i data-lucide="star" size="20"></i>
              <span class="badge" id="bookmarkCount" style="display:none;">0</span>
            </button>
            <button class="icon-btn" onclick="toggleMenu()"><i data-lucide="sliders-horizontal" size="20"></i></button>
          </div>
        </div>
        <div class="search-wrapper">
          <i data-lucide="search" class="search-icon" size="18"></i>
          <input type="text" id="searchInput" class="search-input" placeholder="Buscar repuesto, marca..." oninput="handleSearch()">
          <button class="clear-btn" id="clearSearch" onclick="clearSearch()"><i data-lucide="x" size="14"></i></button>
        </div>
        <div class="filter-row" id="filterPills"></div>
      </div>

      <div id="content" class="grid-container">
        <div class="loading-state"><div class="spinner"></div><div>Cargando inventario...</div></div>
      </div>
    </div>

    <div id="toast" class="toast"></div>

    <script>
      let currentUser = "", currentCategory = "", searchTimer;
      let allItems = [], bookmarks = new Set(), showingBookmarksOnly = false;

      window.onload = function() { lucide.createIcons(); loadBookmarks(); document.getElementById('login-key').focus(); };

      function handleLoginKey(e) { if (e.key === 'Enter') attemptLogin(); }

      function attemptLogin() {
        const keyInput = document.getElementById('login-key');
        const msgEl = document.getElementById('login-msg');
        const btn = document.getElementById('loginBtn');
        const key = keyInput.value.trim();
        if (!key) return;

        msgEl.className = 'login-msg loading';
        msgEl.innerHTML = '<span class="spinning">⏳</span> Verificando...';
        keyInput.disabled = true; btn.disabled = true;

        google.script.run
          .withSuccessHandler((userName) => {
            if (userName) { currentUser = userName; unlockApp(userName); }
            else { keyInput.disabled = false; btn.disabled = false; keyInput.value = ""; keyInput.focus();
              msgEl.className = 'login-msg error'; msgEl.innerHTML = '⛔ Código inválido'; }
          })
          .withFailureHandler(() => {
            msgEl.className = 'login-msg error'; msgEl.innerHTML = '📶 Error de conexión';
            keyInput.disabled = false; btn.disabled = false;
          })
          .validateWarehouseUser(key);
      }

      function unlockApp(userName) {
        document.getElementById('userBadge').textContent = userName;
        document.getElementById('userBadge').style.display = 'block';
        const overlay = document.getElementById('login-overlay');
        overlay.style.opacity = '0';
        setTimeout(() => {
          overlay.style.display = 'none';
          document.getElementById('app-content').style.display = 'block';
          lucide.createIcons(); loadItems(); loadCategories();
        }, 300);
      }

      function logout() {
        currentUser = "";
        document.getElementById('app-content').style.display = 'none';
        const overlay = document.getElementById('login-overlay');
        overlay.style.display = 'flex';
        setTimeout(() => overlay.style.opacity = '1', 10);
        const keyInput = document.getElementById('login-key');
        keyInput.value = ""; keyInput.disabled = false;
        document.getElementById('loginBtn').disabled = false;
        document.getElementById('login-msg').className = 'login-msg';
        document.getElementById('login-msg').innerHTML = '';
        toggleMenu(false);
        setTimeout(() => keyInput.focus(), 100);
      }

      function toggleMenu(forceClose) {
        const menu = document.getElementById('sideMenu');
        const overlay = document.getElementById('menuOverlay');
        if (forceClose === false || menu.classList.contains('open')) {
          menu.classList.remove('open'); overlay.classList.remove('open');
        } else { menu.classList.add('open'); overlay.classList.add('open'); }
      }

      function loadCategories() {
        google.script.run.withSuccessHandler(renderCategories).getUniqueCategories();
      }

      function renderCategories(cats) {
        const list = document.getElementById('categoriesList');
        let html = `<button class="cat-btn ${currentCategory === '' ? 'active' : ''}" onclick="selectCategory('')"><i data-lucide="layers" size="18"></i> Todos</button>`;
        cats.forEach(cat => {
          html += `<button class="cat-btn ${currentCategory === cat ? 'active' : ''}" onclick="selectCategory('${safe(cat)}')"><i data-lucide="tag" size="18"></i> ${cat}</button>`;
        });
        list.innerHTML = html; lucide.createIcons();
        
        // Filter pills
        const pills = document.getElementById('filterPills');
        let pillsHtml = `<button class="filter-pill ${currentCategory === '' ? 'active' : ''}" onclick="selectCategory('')">Todos</button>`;
        cats.slice(0, 5).forEach(cat => {
          pillsHtml += `<button class="filter-pill ${currentCategory === cat ? 'active' : ''}" onclick="selectCategory('${safe(cat)}')">${cat}</button>`;
        });
        pills.innerHTML = pillsHtml;
      }

      function selectCategory(cat) {
        currentCategory = cat; showingBookmarksOnly = false;
        document.getElementById('bookmarkToggle').classList.remove('active');
        toggleMenu(false); loadCategories(); loadItems(document.getElementById('searchInput').value);
      }

      function handleSearch() {
        clearTimeout(searchTimer);
        const query = document.getElementById('searchInput').value;
        document.getElementById('clearSearch').classList.toggle('show', query.length > 0);
        searchTimer = setTimeout(() => loadItems(query), 300);
      }

      function clearSearch() {
        document.getElementById('searchInput').value = '';
        document.getElementById('clearSearch').classList.remove('show');
        loadItems();
      }

      function loadBookmarks() {
        try { const saved = localStorage.getItem('inv_bookmarks'); if (saved) bookmarks = new Set(JSON.parse(saved)); } catch(e) {}
        updateBookmarkCount();
      }

      function saveBookmarks() {
        try { localStorage.setItem('inv_bookmarks', JSON.stringify([...bookmarks])); } catch(e) {}
        updateBookmarkCount();
      }

      function toggleBookmark(itemId) {
        if (bookmarks.has(itemId)) bookmarks.delete(itemId); else bookmarks.add(itemId);
        saveBookmarks();
        const card = document.getElementById(`card-${itemId}`);
        const btn = document.getElementById(`bm-${itemId}`);
        if (card) card.classList.toggle('bookmarked', bookmarks.has(itemId));
        if (btn) btn.classList.toggle('bookmarked', bookmarks.has(itemId));
        if (showingBookmarksOnly && !bookmarks.has(itemId)) renderCards(allItems);
      }

      function updateBookmarkCount() {
        const badge = document.getElementById('bookmarkCount');
        badge.textContent = bookmarks.size;
        badge.style.display = bookmarks.size > 0 ? 'flex' : 'none';
      }

      function toggleBookmarkView() {
        showingBookmarksOnly = !showingBookmarksOnly;
        document.getElementById('bookmarkToggle').classList.toggle('active', showingBookmarksOnly);
        if (showingBookmarksOnly) { currentCategory = ''; loadCategories(); }
        renderCards(allItems);
      }

      function loadItems(query = "") {
        const container = document.getElementById('content');
        container.innerHTML = '<div class="loading-state"><div class="spinner"></div><div>Cargando...</div></div>';
        google.script.run
          .withSuccessHandler((items) => { allItems = items; renderCards(items); })
          .withFailureHandler((err) => {
            container.innerHTML = `<div class="empty-state"><div class="empty-icon">⚠️</div><div class="empty-title">Error</div><div class="empty-text">${err.message}</div></div>`;
          })
          .getInventoryItems(query, currentCategory);
      }

      function renderCards(items) {
        const container = document.getElementById('content');
        let filtered = showingBookmarksOnly ? items.filter(i => bookmarks.has(String(i.id))) : items;

        if (filtered.length === 0) {
          const msg = showingBookmarksOnly
            ? { icon: '⭐', title: 'Sin favoritos', text: 'Marca items con la estrella' }
            : { icon: '📦', title: 'Sin resultados', text: 'Intenta otra búsqueda' };
          container.innerHTML = `<div class="empty-state"><div class="empty-icon">${msg.icon}</div><div class="empty-title">${msg.title}</div><div class="empty-text">${msg.text}</div></div>`;
          return;
        }

        container.innerHTML = filtered.map(item => {
          const isBookmarked = bookmarks.has(String(item.id));
          const safeName = safe(item.name);
          return `
            <div class="card ${isBookmarked ? 'bookmarked' : ''}" id="card-${item.id}">
              <div class="card-header">
                <div class="card-meta">
                  <div class="card-brand">${item.brand || 'Sin marca'}</div>
                  <div class="card-title">${item.name}</div>
                </div>
                <div class="card-actions">
                  <button class="card-btn ${isBookmarked ? 'bookmarked' : ''}" id="bm-${item.id}" onclick="toggleBookmark('${item.id}')"><i data-lucide="star" size="18"></i></button>
                  <button class="card-btn" onclick="openImageSearch('${safeName}')"><i data-lucide="image" size="18"></i></button>
                </div>
              </div>
              <div class="card-body">
                <div class="field-group">
                  <div class="field">
                    <div class="field-label"><i data-lucide="map-pin" size="12"></i> Ubicación</div>
                    <div class="field-input-wrapper">
                      <input type="text" class="field-input" id="loc-${item.id}" value="${item.loc || ''}" placeholder="¿Dónde?" onfocus="this.select()" oninput="markModified('${item.id}', 'loc', this)">
                      <button class="save-btn" id="save-loc-${item.id}" onclick="saveLoc('${item.id}')"><i data-lucide="check" size="20"></i></button>
                    </div>
                  </div>
                  <div class="field" style="max-width:130px;">
                    <div class="field-label"><i data-lucide="package" size="12"></i> Stock</div>
                    <div class="field-input-wrapper">
                      <input type="number" class="field-input stock-field" id="stock-${item.id}" value="${item.stock}" min="0" inputmode="numeric" onfocus="this.select()" oninput="markModified('${item.id}', 'stock', this)">
                      <button class="save-btn" id="save-stock-${item.id}" onclick="saveStock('${item.id}')"><i data-lucide="check" size="20"></i></button>
                    </div>
                  </div>
                </div>
                <div class="quick-actions">
                  <button class="quick-btn" onclick="adjustStock('${item.id}', -1)"><i data-lucide="minus" size="16"></i> 1</button>
                  <button class="quick-btn" onclick="adjustStock('${item.id}', 1)"><i data-lucide="plus" size="16"></i> 1</button>
                  <button class="quick-btn danger" onclick="setZeroStock('${item.id}')"><i data-lucide="alert-triangle" size="16"></i> Sin Stock</button>
                </div>
              </div>
            </div>`;
        }).join('');
        lucide.createIcons();
      }

      function markModified(itemId, field, input) {
        input.classList.add('modified'); input.classList.remove('saved');
        const saveBtn = document.getElementById(`save-${field}-${itemId}`);
        if (saveBtn) { saveBtn.classList.add('show'); lucide.createIcons(); }
      }

      function saveLoc(itemId) {
        const input = document.getElementById(`loc-${itemId}`);
        const saveBtn = document.getElementById(`save-loc-${itemId}`);
        saveBtn.classList.add('saving'); saveBtn.disabled = true;
        google.script.run
          .withSuccessHandler((res) => {
            if (res.success) { input.classList.remove('modified'); input.classList.add('saved'); saveBtn.classList.remove('show', 'saving'); saveBtn.disabled = false; showToast('Ubicación guardada', 'success'); setTimeout(() => input.classList.remove('saved'), 2000); }
            else { saveBtn.classList.remove('saving'); saveBtn.disabled = false; showToast('Error al guardar', 'error'); }
          })
          .withFailureHandler(() => { saveBtn.classList.remove('saving'); saveBtn.disabled = false; showToast('Error de conexión', 'error'); })
          .updateItemLoc(itemId, input.value);
      }

      function saveStock(itemId) {
        const input = document.getElementById(`stock-${itemId}`);
        const saveBtn = document.getElementById(`save-stock-${itemId}`);
        saveBtn.classList.add('saving'); saveBtn.disabled = true;
        google.script.run
          .withSuccessHandler((res) => {
            if (res.success) { input.classList.remove('modified'); input.classList.add('saved'); saveBtn.classList.remove('show', 'saving'); saveBtn.disabled = false; showToast('Stock actualizado', 'success'); setTimeout(() => input.classList.remove('saved'), 2000); }
            else { saveBtn.classList.remove('saving'); saveBtn.disabled = false; showToast('Error al guardar', 'error'); }
          })
          .withFailureHandler(() => { saveBtn.classList.remove('saving'); saveBtn.disabled = false; showToast('Error de conexión', 'error'); })
          .updateItemStock(itemId, input.value);
      }

      function adjustStock(itemId, delta) {
        const input = document.getElementById(`stock-${itemId}`);
        const newVal = Math.max(0, (parseInt(input.value) || 0) + delta);
        input.value = newVal;
        saveStockDirect(itemId, newVal);
      }

      function setZeroStock(itemId) {
        document.getElementById(`stock-${itemId}`).value = 0;
        saveStockDirect(itemId, 0);
      }

      function saveStockDirect(itemId, value) {
        const input = document.getElementById(`stock-${itemId}`);
        input.classList.add('modified');
        google.script.run
          .withSuccessHandler((res) => {
            if (res.success) { input.classList.remove('modified'); input.classList.add('saved'); showToast('Stock actualizado', 'success'); setTimeout(() => input.classList.remove('saved'), 2000); }
            else showToast('Error al guardar', 'error');
          })
          .withFailureHandler(() => showToast('Error de conexión', 'error'))
          .updateItemStock(itemId, value);
      }

      function openImageSearch(itemName) {
        window.open(`https://www.google.com/search?tbm=isch&q=${encodeURIComponent(itemName.replace(/&quot;/g, '').replace(/\\'/g, ''))}`, '_blank');
      }

      function showToast(message, type = '') {
        const toast = document.getElementById('toast');
        toast.className = `toast ${type}`;
        toast.innerHTML = `${type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️'} ${message}`;
        setTimeout(() => toast.classList.add('show'), 10);
        setTimeout(() => toast.classList.remove('show'), 3000);
      }

      function safe(str) { return (str || "").replace(/'/g, "\\'").replace(/"/g, "&quot;"); }
    </script>
  </body>
</html>